# Hockey Capital — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# ---- Supabase ----
# Trouvables dans: supabase.com → ton projet → Settings → API
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # clé service (secret!)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...      # clé publique (pour le frontend)

# ---- Serveur ----
PORT=3001
NODE_ENV=development

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000   # en prod: https://hockey-capital.vercel.app

# ---- Algorithme (VERSION INITIALE — ne pas changer sans noter la version) ----
# Ces valeurs sont dans src/services/priceImpact.js (ALGO constant)
# Modifier ici n'a aucun effet — c'est pour documentation seulement
# WIN_REG=0.04, WIN_OT=0.02, SHUTOUT=0.03, LOSS_REG=0.03, LOSS_OT=0.01
